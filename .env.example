# ============================================
# FAX受注OCR自動転記システム - 環境変数設定
# ============================================
# このファイルをコピーして .env にリネームし、
# 各値を実際の認証情報に置き換えてください。
#
# ⚠ .env ファイルは共有ドライブに置かないでください。
#   ローカル（C:\Users\<ユーザー名>\fax-order-system\.env）に配置してください。
# ============================================

# Anthropic API Key (OCR処理に使用)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase 接続情報 (商品/納品先マスタ参照)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXX

# Google Drive フォルダID (FAX PDF取得元 - drive_processor.py用)
# GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxx
